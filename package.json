{
  "name": "my-ecm",
  "private": true,
  "workspaces": {
    "catalogs": {
      "backend": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/microservices": "^11.1.19",
        "@nestjs/platform-express": "^11.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1"
      },
      "common": {
        "arkenv": "^0.11.0",
        "arktype": "^2.2.0"
      },
      "dev": {
        "@types/bun": "1.3.5",
        "@typescript/native-preview": "^7.0.0-dev.20260424.1"
      }
    },
    "packages": [
      "apps/*",
      "libs/*"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "clean": "rimraf --glob '**/node_modules' '**/.turbo' '**/dist' bun.lock",
    "dev": "turbo run dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "setup": "bun scripts/init.ts && bun i"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260424.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6"
  },
  "packageManager": "bun@1.3.5"
}
