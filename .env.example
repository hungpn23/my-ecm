# ── Global ───────────────────────────────────────────
NODE_ENV=local

# ── Identity Service ─────────────────────────────────
IDENTITY_SERVICE_HTTP_PORT=8080
IDENTITY_SERVICE_TCP_PORT=8180

# ── Product Service ──────────────────────────────────
PRODUCT_SERVICE_HTTP_PORT=8081
PRODUCT_SERVICE_TCP_PORT=8181

# ── Inventory Service ────────────────────────────────
INVENTORY_SERVICE_HTTP_PORT=8082
INVENTORY_SERVICE_TCP_PORT=8182

# ── Search Service ───────────────────────────────────
SEARCH_SERVICE_HTTP_PORT=8083
SEARCH_SERVICE_TCP_PORT=8183

# ── Cart Service ─────────────────────────────────────
CART_SERVICE_HTTP_PORT=8084
CART_SERVICE_TCP_PORT=8184

# ── Order Service ────────────────────────────────────
ORDER_SERVICE_HTTP_PORT=8085
ORDER_SERVICE_TCP_PORT=8185

# ── Payment Service ──────────────────────────────────
PAYMENT_SERVICE_HTTP_PORT=8086
PAYMENT_SERVICE_TCP_PORT=8186

# ── Shipping Service ─────────────────────────────────
SHIPPING_SERVICE_HTTP_PORT=8087
SHIPPING_SERVICE_TCP_PORT=8187

# ── Notification Service ─────────────────────────────
NOTIFICATION_SERVICE_HTTP_PORT=8088
NOTIFICATION_SERVICE_TCP_PORT=8188

# ── Chat Service ─────────────────────────────────────
CHAT_SERVICE_HTTP_PORT=8089
CHAT_SERVICE_TCP_PORT=8189

# ── Review Service ───────────────────────────────────
REVIEW_SERVICE_HTTP_PORT=8090
REVIEW_SERVICE_TCP_PORT=8190

# ── Media Service ────────────────────────────────────
MEDIA_SERVICE_HTTP_PORT=8091
MEDIA_SERVICE_TCP_PORT=8191

# ── Promotion Service ────────────────────────────────
PROMOTION_SERVICE_HTTP_PORT=8092
PROMOTION_SERVICE_TCP_PORT=8192

# ── Report Service ───────────────────────────────────
REPORT_SERVICE_HTTP_PORT=8093
REPORT_SERVICE_TCP_PORT=8193

# ── PostgreSQL ───────────────────────────────────────
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_DATABASE=postgres

# ── Redis ────────────────────────────────────────────
REDIS_PORT=6379

# ── APISIX ───────────────────────────────────────────
APISIX_PORT=9080

# ── Kafka ────────────────────────────────────────────
KAFKA_PORT=9192
