{
	"routes": [
		{
			"id": "auth-service",
			"uri": "/auth/*",
			"plugins": {
				"proxy-rewrite": {
					"regex_uri": ["^/auth/(.*)", "/$1"]
				}
			},
			"upstream": {
				"nodes": { "host.docker.internal:8080": 1 },
				"type": "roundrobin"
			}
		},
		{
			"id": "user-service",
			"uri": "/user/*",
			"plugins": {
				"proxy-rewrite": {
					"regex_uri": ["^/user/(.*)", "/$1"]
				}
			},
			"upstream": {
				"nodes": { "host.docker.internal:8081": 1 },
				"type": "roundrobin"
			}
		}
	]
}
